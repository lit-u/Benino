{
  "manifest_version": 3,
  "name": "STT Clipboard",
  "version": "1.0",
  "description": "Kalbėk → tekstas į clipboard",
  "permissions": ["clipboardWrite", "microphone", "windows"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+S"
      },
      "description": "Atidaryti STT"
    }
  }
}
