# Benino Configuration Template
# Nukopijuokite į .env ir užpildykite savo raktais

# === AI Model Providers ===

# Gemini (Google)
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-1.5-flash

# Claude (Anthropic)
ANTHROPIC_API_KEY=your-anthropic-api-key-here
# ANTHROPIC_MODEL=claude-sonnet-4-5

# Groq
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# OpenAI
OPENAI_API_KEY=your-openai-api-key-here
# OPENAI_MODEL=gpt-4o

# === Application Settings ===

NODE_ENV=development
PORT=3000

# === Supabase Database ===
SUPABASE_URL=your-supabase-url
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-key

# === Azure Speech ===
AZURE_SPEECH_KEY=your-azure-speech-key
AZURE_SPEECH_REGION=your-region

# === Messaging Channels ===

# Twilio (WhatsApp/SMS)
# Copy to .env and fill with your Twilio credentials
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
# Must be a WhatsApp-enabled Twilio number, prefixed with whatsapp:
TWILIO_WHATSAPP_FROM=whatsapp:+17343367101

# === Other Settings ===
CORS_ORIGIN=*
DATA_RETENTION_DAYS=30
USE_NEW_TOOLS=true
USE_CROSS_AGENT=true

# === Timeouts ===
GROQ_TIMEOUT=2000
OPENAI_TIMEOUT=3000

# === LLM Cache ===
ENABLE_LLM_CACHE=true
